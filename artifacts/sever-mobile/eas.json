{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_DOMAIN": "YOUR_REPLIT_APP_DOMAIN_HERE"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {},
      "env": {
        "EXPO_PUBLIC_DOMAIN": "YOUR_REPLIT_APP_DOMAIN_HERE"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
